<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Reports - DWU</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="container">
    <h1>📊 System Reports</h1>
    <h2>Student Statistics</h2>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; margin: 30px 0;">
      <div style="background:#f8f9fa; padding:25px; border-radius:12px; text-align:center;">
        <h3>Total Students</h3>
        <h1 style="color:#667eea;"><%= totalStudents %></h1>
      </div>
      <div style="background:#f8f9fa; padding:25px; border-radius:12px; text-align:center;">
        <h3>Residential</h3>
        <h1 style="color:#27ae60;"><%= residential %></h1>
      </div>
      <div style="background:#f8f9fa; padding:25px; border-radius:12px; text-align:center;">
        <h3>Non-Residential</h3>
        <h1 style="color:#f39c12;"><%= nonResidential %></h1>
      </div>
      <div style="background:#f8f9fa; padding:25px; border-radius:12px; text-align:center;">
        <h3>Total Amount Due</h3>
        <h1 style="color:#e74c3c;">K <%= totalDue.toFixed(2) %></h1>
      </div>
    </div>

    <br>
    <a href="/admin/dashboard"><button>← Back to Admin Dashboard</button></a>
  </div>
</body>
</html>