<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DWU Login</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="container">
    <h1>🌟 Divine Word University</h1>
    <h2>Student Registration & Accommodation System</h2>
    
    <form action="/login" method="POST">
      <input type="text" name="username" placeholder="Username" required>
      <input type="password" name="password" placeholder="Password" required>
      <button type="submit">Login</button>
    </form>

    <p style="text-align:center; margin-top:25px; font-size:15px;">
      <strong>Demo Accounts:</strong><br><br>
      👨‍🎓 <strong>mary / 123</strong> — Student<br>
      💰 <strong>finance / 123</strong> — Finance Officer<br>
      🛠️ <strong>admin / 123</strong> — Administrator<br>
      🏠 <strong>accom / 123</strong> — Accommodation Officer
    </p>
  </div>
</body>
</html>