<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Manage Users - DWU</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="container">
    <h1>🔧 Manage User Accounts</h1>
    <h2>All System Users</h2>

    <table>
      <tr>
        <th>Username</th>
        <th>Full Name</th>
        <th>Role</th>
        <th>Password</th>
        <th>Action</th>
      </tr>
      <% users.forEach(user => { %>
      <tr>
        <td><%= user.username %></td>
        <td><%= user.first_name %> <%= user.last_name || '' %></td>
        <td><%= user.role %></td>
        <td><%= user.password %></td>
        <td>
          <button onclick="alert('Password for <%= user.username %> has been reset to 123')">Reset Password</button>
        </td>
      </tr>
      <% }); %>
    </table>

    <br><br>
    <a href="/admin/dashboard"><button>← Back to Admin Dashboard</button></a>
  </div>
</body>
</html>