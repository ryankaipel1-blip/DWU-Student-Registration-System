<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Add New Student - DWU</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="container">
    <h1>➕ Add New Student</h1>
    
    <form action="/admin/add-student" method="POST">
      <label>Student ID:</label>
      <input type="text" name="student_id" placeholder="S23003" required><br><br>

      <label>First Name:</label>
      <input type="text" name="first_name" required><br><br>

      <label>Last Name:</label>
      <input type="text" name="last_name" required><br><br>

      <label>Residency Status:</label>
      <select name="residency_type">
        <option value="Residential">Residential</option>
        <option value="Non-Residential">Non-Residential</option>
      </select><br><br>

      <h3>Login Credentials for Student</h3>
      <label>Username:</label>
      <input type="text" name="username" placeholder="e.g. ryan" required><br><br>

      <label>Password:</label>
      <input type="text" name="password" value="123" required><br><br>

      <button type="submit">Add Student</button>
    </form>

    <br>
    <a href="/admin/dashboard"><button>← Back to Admin Dashboard</button></a>
  </div>
</body>
</html>