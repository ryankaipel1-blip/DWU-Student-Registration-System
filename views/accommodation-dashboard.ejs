<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Accommodation Dashboard - DWU</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="container">
    <h1>🏠 Accommodation Office Dashboard</h1>
    <h2>Room Allocation Management</h2>
    
    <table>
      <tr>
        <th>Student ID</th>
        <th>Name</th>
        <th>Status</th>
        <th>Room Assignment</th>
      </tr>
      <tr>
        <td>S23001</td>
        <td>Mary Kila</td>
        <td class="status-approved">Approved</td>
        <td>
          <input type="text" placeholder="e.g. Block A - Room 105" id="room">
          <button onclick="assignRoom()">Assign Room</button>
        </td>
      </tr>
    </table>

    <br>
    <a href="/logout"><button style="background:#e74c3c;">Logout</button></a>
  </div>

  <script>
    function assignRoom() {
      const room = document.getElementById('room').value;
      if (room) {
        alert(`Room ${room} has been assigned to Mary Kila successfully!`);
      } else {
        alert("Please enter a room number");
      }
    }
  </script>
</body>
</html>