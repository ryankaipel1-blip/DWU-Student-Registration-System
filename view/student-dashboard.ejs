<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Student Dashboard - DWU</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="container">
    <h1>Welcome, <%= user.first_name %> <%= user.last_name %>!</h1>
    <p><strong>Student ID:</strong> <%= user.student_id %></p>
    <p><strong>Current Residency:</strong> <span class="<%= user.residency_type === 'Residential' ? 'status-approved' : 'status-pending' %>"><%= user.residency_type %></span></p>
    <p><strong>Fee Status:</strong> <%= user.fee_status %></p>

    <% if (user.residency_type === 'Non-Residential') { %>
      <a href="/student/request-change"><button>Request Change to Residential</button></a>
    <% } else { %>
      <p class="status-approved">✅ You are Residential. Go to Accommodation Office for room key.</p>
    <% } %>

    <br><a href="/logout"><button style="background:red;">Logout</button></a>
  </div>
</body>
</html>